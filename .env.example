# Supabase Configuration (Required for Leaderboard)
# Get these from your Supabase Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Table Name (Default: leaderboard)
# Ensure this table exists with 'username' (text) and 'score' (int8) columns.
SUPABASE_TABLE_NAME=leaderboard

# AdMob Configuration (Optional - Defaults to Test IDs)
# Get these from https://admob.google.com/
VITE_ADMOB_REWARDED_ID=ca-app-pub-3940256099942544/5224354917

# APK Download URL (Optional)
# The URL where your APK is hosted (e.g., on GitHub Releases or a CDN)
VITE_APK_DOWNLOAD_URL=https://example.com/neon-dash.apk
